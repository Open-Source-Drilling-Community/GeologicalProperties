    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        //Delete possible old values
        valueData.Clear();
        var file = e.File;
        fileName = file.Name;
        if (File.Exists(fileName))
        {
            using (StreamReader reader = new StreamReader(fileName))
            {
                string? line;
                bool headerLine = false;
                while ((line = await reader.ReadLineAsync()) != null)
                {
                    string[] values = line.Split(';', '\t');
                    maxColumns = values.Length;
                    double?[] valuesDouble = new double?[maxColumns];
                    for (int i = 0; i < maxColumns; i++)
                    {
                        double valDouble;
                        //Check for empty strings
                        if (string.IsNullOrEmpty(values[i]))
                        {
                            valuesDouble[i] = null;
                            headerLine = false;
                        }
                        else
                        {
                            //Try to parse doubles
                            if (Double.TryParse(values[i], out valDouble))
                            {
                                valuesDouble[i] = valDouble;
                                headerLine = false;
                            }
                            else
                            {
                                headerLine = true;
                            }
                        }
                    }//Close for loop
                    if (headerLine)
                    {
                        headerData = values;
                    }//Close if header
                    else
                    {
                        valueData.Add(valuesDouble);
                    }//Close else
                }//Close while loop
            }
            showTable = true;
            maxRows = valueData.Count;
            if (currentGeologicalProperties != null && maxRows > 0 && valueData != null && valueData.Count == maxRows)
            {
                List<GeologicalPropertyEntry> propertiesTable = new List<GeologicalPropertyEntry>();
                currentGeologicalProperties.GeologicalPropertyTable = propertiesTable;
                for (int i = 0; i < maxRows; i++)
                {
                    propertiesTable.Add(PseudoConstructors.ConstructGeologicalPropertyEntry());
                }
                try
                {
                    //Internal friction angle
                    if (internalFrictionAngleColumn != null && internalFrictionAngleUnit != null)
                    {
                        UnitChoice unitChoice = angleDictUnits[internalFrictionAngleUnit];
                        for (int i = 0; i < maxRows; i++)
                        {
                            double? val = valueData[i][(int)internalFrictionAngleColumn - 1];
                            double? valSI = ConvertToSI(val, unitChoice);
                            propertiesTable[i].InternalFrictionAngle =
                                PseudoConstructors.ConstructGaussianDrillingProperty(valSI);
                        }
                    }
                    //Unconfined Compressive Strength
                    if (ucsColumn != null && ucsUnit != null)
                    {
                        UnitChoice unitChoice = stressDictUnits[ucsUnit];
                        for (int i = 0; i < maxRows; i++)
                        {
                            double? val = valueData[i][(int)ucsColumn - 1];
                            double? valSI = ConvertToSI(val, unitChoice);
                            propertiesTable[i].UnconfinedCompressiveStrength =
                                PseudoConstructors.ConstructGaussianDrillingProperty(valSI);
                        }
                    }
                    //Confined Compressive Strength
                    if (pressureColumn != null && pressureUnit != null)
                    {
                        UnitChoice unitChoice = pressureDictUnits[pressureUnit];
                        for (int i = 0; i < maxRows; i++)
                        {
                            double? val = valueData[i][(int)pressureColumn - 1];
                            double? valSI = ConvertToSI(val, unitChoice);
                            propertiesTable[i].PressureDifferential =
                                PseudoConstructors.ConstructGaussianDrillingProperty(valSI);
                        }
                    }
                    //Porosity
                    if (porosityColumn != null && porosityUnit != null)
                    {
                        UnitChoice unitChoice = porosityDictUnits[porosityUnit];
                        for (int i = 0; i < maxRows; i++)
                        {
                            double? val = valueData[i][(int)porosityColumn - 1];
                            double? valSI = ConvertToSI(val, unitChoice);
                            propertiesTable[i].Porosity =
                                PseudoConstructors.ConstructGaussianDrillingProperty(valSI);
                        }
                    }
                    //Permeability
                    if (permeabilityColumn != null && permeabilityUnit != null)
                    {
                        UnitChoice unitChoice = permeabilityDictUnits[permeabilityUnit];
                        for (int i = 0; i < maxRows; i++)
                        {
                            double? val = valueData[i][(int)permeabilityColumn - 1];
                            double? valSI = ConvertToSI(val, unitChoice);
                            propertiesTable[i].Permeability =
                                PseudoConstructors.ConstructGaussianDrillingProperty(valSI);
                        }
                    }
                    //MeasuredDepth
                    if (measuredDepthColumn != null && measuredDepthUnit != null)
                    {
                        UnitChoice unitChoice = depthDictUnits[measuredDepthUnit];
                        for (int i = 0; i < maxRows; i++)
                        {
                            double? val = valueData[i][(int)measuredDepthColumn - 1];
                            double? valSI = ConvertToSI(val, unitChoice);
                            propertiesTable[i].MeasuredDepth =
                                PseudoConstructors.ConstructGaussianDrillingProperty(valSI);
                        }
                    }
                }
                catch (Exception)
                {
                    logger.LogWarning("Table not loaded correctly");
                    Snackbar.Add("Table not loaded correctly", Severity.Warning);
                }
            }
        }
    }
    private double? ConvertToSI(double? val, UnitChoice unitChoice)
    {
        double? valSI;
        if (val == null)
        {
            valSI = null;
        }
        else
        {
            valSI = unitChoice.ToSI((double)val);
        }
        return valSI;
    }

