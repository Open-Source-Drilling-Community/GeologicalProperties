@inject ILogger<MudInputWithUnitAdornment> logger
@inject ISnackbar Snackbar
@if (GeologicalPropertiesInterpolationCaseID != null && Parent != null)
{
    <MudPaper Class="my-1 mx-1 py-4" Style="@($"background:{DataUtils.FLOATING_COLOUR};")">
        <MudPaper Class="my-4 mx-2 py-2">
            <MudToolBar>
                <MudText Class="my-4 mx-2 py-2" Typo="Typo.h6">
                    View Data
                </MudText>
                <MudSpacer />
                <MudButton StartIcon="@Icons.Material.Outlined.Close" IconColor="@Color.Error"
                           OnClick="@ClosePanel">Close</MudButton>
            </MudToolBar>
            <MudPaper Class="my-4 mx-2 py-2" Style="@($"background:{DataUtils.FLOATING_COLOUR_DEEP};")">
                <MudGrid Class="my-4 mx-2 py-2">
                    <MudItem xs="3">
                        <MudText Typo="Typo.body1"><b>Name:</b></MudText>
                        <MudText Typo="Typo.body1">@currentGeologicalPropertiesInterpolationCase.Name</MudText>
                    </MudItem>
                    <MudItem xs="3">
                        <MudText Typo="Typo.body1"><b>Description:</b></MudText>
                        <MudText Typo="Typo.body1">@currentGeologicalPropertiesInterpolationCase.Description</MudText>
                    </MudItem>
                    <MudItem xs="3">
                        <MudText Typo="Typo.body1"><b>Creation Date:</b></MudText>
                        <MudText Typo="Typo.body1">@currentGeologicalPropertiesInterpolationCase.CreationDate.ToString()</MudText>
                    </MudItem>
                    <MudItem xs="3">
                        <MudText Typo="Typo.body1"><b>Last Modification Date:</b></MudText>
                        <MudText Typo="Typo.body1">@currentGeologicalPropertiesInterpolationCase.LastModificationDate.ToString()</MudText>
                    </MudItem>
                    <MudItem xs="2">
                        <MudText Typo="Typo.body1"><b>Field:</b></MudText>
                        <MudText Typo="Typo.body1">@((_selectedField == null) ? string.Empty : _selectedField.Name)</MudText>
                    </MudItem>
                    <MudItem xs="2">
                        <MudText Typo="Typo.body1"><b>Cluster:</b></MudText>
                        <MudText Typo="Typo.body1">@((_selectedCluster == null) ? string.Empty : _selectedCluster.Name)</MudText>
                    </MudItem>
                    <MudItem xs="2">
                        <MudText Typo="Typo.body1"><b>Well:</b></MudText>
                        <MudText Typo="Typo.body1">@((_selectedWell == null) ? string.Empty : _selectedWell.Name)</MudText>
                    </MudItem>
                    <MudItem xs="2">
                        <MudText Typo="Typo.body1"><b>Wellbore:</b></MudText>
                        <MudText Typo="Typo.body1">@((_selectedWellBore == null) ? string.Empty : _selectedWellBore.Name)</MudText>
                    </MudItem>
                    <MudItem xs="2">
                        <MudText Typo="Typo.body1"><b>Geo. Prop.:</b></MudText>
                        <MudText Typo="Typo.body1">@((_selectedGeologicalProperties == null) ? string.Empty : _selectedGeologicalProperties.Name)</MudText>
                    </MudItem>
                </MudGrid>
                @* Charts *@
                <MudPaper Class="my-4 mx-2 py-2">
                    <MudToolBar>
                        <MudText Class="my-4 mx-2 py-2" Typo="Typo.h6">
                            Charts
                        </MudText>
                        <MudSpacer />
                        <MudButton StartIcon="@Icons.Material.Filled.SsidChart" IconColor="@Color.Primary"
                                   OnClick="@HideShowChart">@showChartText</MudButton>
                    </MudToolBar>
                    <MudCollapse Expanded="@showChart">
                        <MudToolBar>
                            <MudSpacer />
                            <MudPaper Class="pl-3 ml-3" Height="20px" Width="20px" Style="@($"background:{interpolatedColor};")" />
                            <MudText Class="px-1 mx-1"> Interpolated data </MudText>
                            <MudPaper Class="pl-3 ml-3" Height="20px" Width="20px" Style="@($"background:{extrapolatedColor};")" />
                            <MudText Class="px-1 mx-1"> Extrapolated data </MudText>
                            <MudSpacer />
                        </MudToolBar>
                        <MudGrid>
                            <MudItem xs="4">
                                <PlotlyChart @bind-Config="config" @bind-Layout="layoutInternalFrictionAngle" @bind-Data="dataInternalFrictionAngle" @ref="chartInternalFrictionAngle" />
                            </MudItem>
                            <MudItem xs="4">
                                <PlotlyChart @bind-Config="config" @bind-Layout="layoutPorosity" @bind-Data="dataPorosity" @ref="chartPorosity" />
                            </MudItem>
                            <MudItem xs="4">
                                <PlotlyChart @bind-Config="config" @bind-Layout="layoutPermeability" @bind-Data="dataPermeability" @ref="chartPermeability" />
                            </MudItem>
                        </MudGrid>
                        <MudGrid>
                            <MudItem xs="4">
                                <PlotlyChart @bind-Config="config" @bind-Layout="layoutUCS" @bind-Data="dataUCS" @ref="chartUCS" />
                            </MudItem>
                            <MudItem xs="4">
                                <PlotlyChart @bind-Config="config" @bind-Layout="layoutPressure" @bind-Data="dataPressure" @ref="chartPressure" />
                            </MudItem>
                            <MudItem xs="4">
                                <PlotlyChart @bind-Config="config" @bind-Layout="layoutCCS" @bind-Data="dataCCS" @ref="chartCCS" />
                            </MudItem>
                        </MudGrid>
                    </MudCollapse>
                </MudPaper>
                <MudPaper Class="my-4 mx-2 py-2">
                    <MudToolBar>
                        <MudText Class="my-4 mx-2 py-2" Typo="Typo.h6">
                            Table
                        </MudText>
                        <MudSpacer />
                        <MudButton StartIcon="@Icons.Material.Filled.TableChart" IconColor="@Color.Primary"
                                   OnClick="@HideShowTable">@showTableText</MudButton>
                    </MudToolBar>
                    <MudCollapse Expanded="@showTable">
                        <MudToolBar>
                            <MudSpacer />
                            <MudPaper Class="pl-3 ml-3" Height="20px" Width="20px" Style="@($"background:{interpolatedColor};")" />
                            <MudText Class="px-1 mx-1"> Interpolated data </MudText>
                            <MudPaper Class="pl-3 ml-3" Height="20px" Width="20px" Style="@($"background:{extrapolatedColor};")" />
                            <MudText Class="px-1 mx-1"> Extrapolated data </MudText>
                            <MudSpacer />
                        </MudToolBar>
                        <MudTable Class="my-4 mx-2 py-2" T="GeologicalPropertyEntry" Items="@completeTable" Dense="true" RowStyleFunc="@RowStyleFunc">
                            <HeaderContent>
                                <MudTh>Measured Depth [@(Parent.GetUnitLabel("DepthDrilling"))]</MudTh>
                                <MudTh>Internal Friction Angle [@(Parent.GetUnitLabel("PlaneAngleDrilling"))]</MudTh>
                                <MudTh>Porosity</MudTh>
                                <MudTh>Permeability [@(Parent.GetUnitLabel("PorousMediumPermeabilityDrilling"))]</MudTh>
                                <MudTh>UCS [@(Parent.GetUnitLabel("FormationStrengthDrilling"))]</MudTh>
                                <MudTh>Pressure Differential [@(Parent.GetUnitLabel("PressureDrilling"))]</MudTh>
                                <MudTh>CCS [@(Parent.GetUnitLabel("FormationStrengthDrilling"))]</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@PrepareForTable(context.MeasuredDepth, "DepthDrilling")</MudTd>
                                <MudTd>@PrepareForTable(context.InternalFrictionAngle, "PlaneAngleDrilling")</MudTd>
                                <MudTd>@PrepareForTable(context.Porosity, "Porosity")</MudTd>
                                <MudTd>@PrepareForTable(context.Permeability, "PorousMediumPermeabilityDrilling")</MudTd>
                                <MudTd>@PrepareForTable(context.UnconfinedCompressiveStrength, "FormationStrengthDrilling")</MudTd>
                                <MudTd>@PrepareForTable(context.PressureDifferential, "PressureDrilling")</MudTd>
                                <MudTd>@PrepareForTable(context.ConfinedCompressiveStrength, "FormationStrengthDrilling")</MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudCollapse>
                </MudPaper>
            </MudPaper>
        </MudPaper>
    </MudPaper>
}


