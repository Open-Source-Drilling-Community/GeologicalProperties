    protected override async Task OnParametersSetAsync()
    {
        if (GeologicalPropertiesInterpolationCaseID != null)
        {
            try
            {
                //Load geological properties if ID is available
                currentGeologicalPropertiesInterpolationCase = (GeologicalPropertiesInterpolationCase)await APIUtils.ClientGeologicalProperties.
                    GetGeologicalPropertiesInterpolationCaseByIdAsync((Guid)GeologicalPropertiesInterpolationCaseID);
                if (currentGeologicalPropertiesInterpolationCase != null)
                {
                    Guid? caseGeoPropID = currentGeologicalPropertiesInterpolationCase.GeologicalPropertiesID;
                    if (caseGeoPropID != null && caseGeoPropID != Guid.Empty)
                    {
                        GeologicalPropertiesLight? geologicalProperties = null;
                        if (GeologicalProperties != null)
                        {
                            foreach (var gplKPV in GeologicalProperties)
                            {
                                if (gplKPV.Value != null && gplKPV.Value.MetaInfo != null && gplKPV.Value.MetaInfo.ID == currentGeologicalPropertiesInterpolationCase.GeologicalPropertiesID)
                                {
                                    geologicalProperties = gplKPV.Value;
                                    break;
                                }
                            }
                        }
                        if (geologicalProperties != null && geologicalProperties.WellBoreID != null && geologicalProperties.WellBoreID != Guid.Empty)
                        {
                            _selectedGeologicalProperties = geologicalProperties;
                            WellBore wellBore = await APIUtils.ClientWellBore.GetWellBoreByIdAsync(geologicalProperties.WellBoreID.Value);
                            if (wellBore != null && wellBore.WellID != null && wellBore.WellID != Guid.Empty)
                            {
                                _selectedWellBore = wellBore;
                                Well well = await APIUtils.ClientWell.GetWellByIdAsync(wellBore.WellID.Value);
                                if (well != null && well.ClusterID != null && well.ClusterID != Guid.Empty)
                                {
                                    _selectedWell = well;
                                    Cluster cluster = await APIUtils.ClientCluster.GetClusterByIdAsync(well.ClusterID.Value);
                                    if (cluster != null && cluster.FieldID != null && cluster.FieldID != Guid.Empty)
                                    {
                                        if (cluster.ReferenceDepth != null && cluster.ReferenceDepth.GaussianValue != null && cluster.ReferenceDepth.GaussianValue.Mean != null)
                                        {
                                            DataUtils.UnitAndReferenceParameters.WellHeadDepthReferenceSource.WellHeadDepthReference = cluster.ReferenceDepth.GaussianValue.Mean;
                                        }
                                        // if (cluster.RotaryTableDepth != null && cluster.RotaryTableDepth.DiracDistributionValue != null && cluster.RotaryTableDepth.DiracDistributionValue.Value != null)
                                        // {
                                        //     DataUtils.UnitAndReferenceParameters.RotaryTableDepthReferenceSource.RotaryTableDepthReference = cluster.RotaryTableDepth.DiracDistributionValue.Value;
                                        // }
                                        if (cluster.GroundMudLineDepth != null && cluster.GroundMudLineDepth.GaussianValue != null && cluster.GroundMudLineDepth.GaussianValue.Mean != null)
                                        {
                                            DataUtils.UnitAndReferenceParameters.GroundMudLineDepthReferenceSource.GroundMudLineDepthReference = cluster.GroundMudLineDepth.GaussianValue.Mean;
                                        }
                                        if (cluster.TopWaterDepth != null && cluster.TopWaterDepth.GaussianValue != null && cluster.TopWaterDepth.GaussianValue.Mean != null)
                                        {
                                            DataUtils.UnitAndReferenceParameters.SeaWaterLevelDepthReferenceSource.SeaWaterLevelDepthReference = cluster.TopWaterDepth.GaussianValue.Mean;
                                        }
                                        if (!cluster.IsSingleWell)
                                        {
                                            _selectedCluster = cluster;
                                        }
                                        Field field = await APIUtils.ClientField.GetFieldByIdAsync(cluster.FieldID.Value);
                                        if (field != null)
                                        {
                                            _selectedField = field;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    hasInterpolation = currentGeologicalPropertiesInterpolationCase.GeologicalPropertyInterpolatedTable != null;
                    if (hasInterpolation && currentGeologicalPropertiesInterpolationCase.GeologicalPropertyInterpolatedTable != null && currentGeologicalPropertiesInterpolationCase.GeologicalPropertyInterpolatedTable is List<GeologicalPropertyEntry> list1)
                    {
                        geologicalPropertyInterpolatedTable = list1;
                    }
                    hasExtrapolation = currentGeologicalPropertiesInterpolationCase.GeologicalPropertyExtrapolatedTable != null;
                    if (hasExtrapolation && currentGeologicalPropertiesInterpolationCase.GeologicalPropertyExtrapolatedTable != null && currentGeologicalPropertiesInterpolationCase.GeologicalPropertyExtrapolatedTable is List<GeologicalPropertyEntry> list2)
                    {
                        geologicalPropertyExtrapolatedTable = list2;
                    }
                }
                CreateFullTable();
                LoadPlotData();
            }//Close try get currentGeologicalProperties
            catch (Exception ex)
            {
                logger.LogError(ex, "Impossible to load geological properties Interpolation Case from client");
            }
        }//Close if GeologicalPropertiesID != null
    }//Close OnParametersSetAsync
    private void CreateFullTable()
    {
        completeTable.Clear();
        if (hasInterpolation)
        {
            completeTable = completeTable.Concat(geologicalPropertyInterpolatedTable).ToList();
        }
        if (hasExtrapolation)
        {
            completeTable = completeTable.Concat(geologicalPropertyExtrapolatedTable).ToList();
        }
        completeTable = completeTable.OrderBy(o => o.MeasuredDepth.GaussianValue.Mean).ToList();

    }
    private string PrepareForTable(GaussianDrillingProperty value, string unitName)
    {
        double? outVal = ConversionsFromOSDC.GaussianToDouble(value);
        if (outVal == null || Parent == null)
        {
            return "";
        }
        else
        {
            double unformatedDouble = Parent.FromSI((double)outVal, unitName);
            double formatedDouble = Math.Round(1000.0 * unformatedDouble) / 1000.0;//(double) ( ((int) (unformatedDouble * 100) )/100.0);
            return formatedDouble.ToString();
        }
    }
    private Func<GeologicalPropertyEntry, int, string> RowStyleFunc => (x, i) =>
    {
        string style = "";
        switch (x.DataType)
        {
            case GeologicalPropertyTableOrigin.Interpolated:
                {
                    style += "background-color:" + interpolatedColor;
                    break;
                }
            case GeologicalPropertyTableOrigin.Extrapolated:
                {
                    style += "background-color:" + extrapolatedColor;
                    break;
                }

        }
        return style;
    };
    private object? PrepareForChart(GaussianDrillingProperty value, string unitName)
    {
        double? valueDouble = ConversionsFromOSDC.GaussianToDouble(value);
        if (valueDouble == null || Parent == null)
        {
            return null;
        }
        else
        {
            return (object)Parent.FromSI((double)valueDouble, unitName);
        }
    }
    private void LoadPlotData()
    {
        if (Parent != null)
        {
            //Clear old lists
            //Interpolated data
            measuredDepthInterpolatedData.Clear();
            internalFrictionAngleInterpolatedData.Clear();
            porosityInterpolatedData.Clear();
            ccsInterpolatedData.Clear();
            ucsInterpolatedData.Clear();
            pressureInterpolatedData.Clear();
            permeabilityInterpolatedData.Clear();
            //Extrapolated data
            measuredDepthExtrapolatedData.Clear();
            internalFrictionAngleExtrapolatedData.Clear();
            porosityExtrapolatedData.Clear();
            ccsExtrapolatedData.Clear();
            ucsExtrapolatedData.Clear();
            pressureExtrapolatedData.Clear();
            permeabilityExtrapolatedData.Clear();

            //Clear charts
            if (chartInternalFrictionAngle != null)
            {
                chartInternalFrictionAngle.Clear();
            }
            if (chartPorosity != null)
            {
                chartPorosity.Clear();
            }
            if (chartPermeability != null)
            {
                chartPermeability.Clear();
            }
            if (chartUCS != null)
            {
                chartUCS.Clear();
            }
            if (chartCCS != null)
            {
                chartCCS.Clear();
            }
            if (chartPressure != null)
            {
